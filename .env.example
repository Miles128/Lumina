# LLM (OpenAI-compatible). 仅使用灵犀自己的 .env 配置，不复用 Hermes 的 KEY。
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Prompt gate: optional LLM classifier before agent loop (default: rules-only)
PROMPT_GATE_ENABLED=false
PROMPT_GATE_MIN_CONFIDENCE=0.6

# Web search APIs (FR-29). Prefer these over HTML scrapers when set.
